# -------------------------
# Frontend Variables
# -------------------------
# VITE_API_BASE_URL is the base URL the frontend uses to contact the backend API.
# For Vercel deployments where frontend and backend are hosted together, leave this empty,
# or set it to /api (unless explicitly set to a different domain).
VITE_API_BASE_URL=

# -------------------------
# Backend Server Variables
# -------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database
DB_PROVIDER=mongodb
# If using SQLite
DATABASE_PATH=./data/startup-validation.db
# If using MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/test

# -------------------------
# AI & External APIs
# -------------------------
# The API Key used for the AI provider (e.g., OpenAI, Gemini, Anthropic)
API_KEY=
# Explicit Provider Keys (used dynamically by config)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Model Selection Config
AI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o

# Search API Keys
TAVILY_API_KEY=
SERPAPI_KEY=
